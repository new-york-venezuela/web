---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import CTASection from '../components/CTASection.astro';
import WhatsAppCTA from '../components/WhatsAppCTA.astro';
import { productos } from '../data/catalogo';

const destacados = productos.filter((p) => p.destacado);
---

<BaseLayout
  title="New York — Alimentos Premium en Caracas"
  description="Alimentos Premium de Nueva York. Panes artesanales, cheesecakes, pizzas y especialidades para supermercados y servicio profesional en Caracas."
>
  <section class="hero">
    <div class="container hero-content">
      <div class="hero-text">
        <span class="eyebrow">Alimentos Premium · Caracas</span>
        <h1>Calidad premium en cada<br />producto que servimos.</h1>
        <p class="lead">
          Panes artesanales, repostería fina y especialidades culinarias.
          Desde supermercados hasta las mesas más exigentes de restaurantes
          y hoteles en Caracas. New York Alimentos Premium, hecho con cuidado.
        </p>
        <div class="hero__actions">
          <a href="/catalogo/" class="btn btn--solid">Ver catálogo</a>
          <a href="/solicitar-llamada/" class="btn btn--solid">Solicitar llamada</a>
          <a href="/sobre-nosotros/" class="btn">Nuestra historia</a>
        </div>
      </div>
      <div class="hero-cta">
        <WhatsAppCTA />
      </div>
    </div>
  </section>

  <section class="section section--milk">
    <div class="container">
      <span class="eyebrow">Nuestro Enfoque</span>
      <h2>Excelencia en cada detalle.</h2>
      <div class="philosophy">
        <div>
          <h3>Ingredientes Premium</h3>
          <p>
            Materias primas seleccionadas cuidadosamente. Sin aditivos innecesarios,
            sin preservantes artificiales. Solo lo mejor.
          </p>
        </div>
        <div>
          <h3>Proceso Artesanal</h3>
          <p>
            Cada producto elaborado con técnicas tradicionales y control de calidad.
            El tiempo y el cuidado hacen la diferencia.
          </p>
        </div>
        <div>
          <h3>Dos Mercados</h3>
          <p>
            Productos versátiles para supermercados y líneas especializadas
            para restaurantes y servicio profesional de calidad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <span class="eyebrow">Selección</span>
      <h2>Los favoritos de la casa</h2>
      <div class="grid">
        {destacados.map((producto) => <ProductCard producto={producto} />)}
      </div>
      <div class="section__cta">
        <a href="/catalogo/" class="btn">Explorar el catálogo completo</a>
      </div>
    </div>
  </section>

  <CTASection
    title="¿Necesitas precios y disponibilidad?"
    description="Nuestro equipo te ofrecerá presupuestos personalizados según tu volumen y tipo de negocio."
    ctaText="Solicitar una Llamada"
  />
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-xl);
    text-align: left;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-l);
    align-items: start;
  }

  .hero-text {
    /* content flows naturally */
  }

  .hero-cta {
    /* sticky or fixed height */
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    margin-top: var(--space-m);
  }

  @media (max-width: 48rem) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--space-m);
    }
  }

  .philosophy {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-l);
    margin-top: var(--space-m);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-m);
    margin-top: var(--space-m);
  }

  .section__cta {
    margin-top: var(--space-l);
    text-align: center;
  }
</style>
