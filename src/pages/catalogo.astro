---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { productos, type Producto } from '../data/catalogo';

const secciones: { titulo: string; nota: string; categoria: Producto['categoria'] }[] = [
  {
    titulo: 'Los clásicos',
    nota: 'La receta neoyorquina en tres formatos, del molde familiar a la porción del café.',
    categoria: 'clasico',
  },
  {
    titulo: 'Toppings artesanales',
    nota: 'Compotas y coulis de cocción corta, elaborados con fruta venezolana de temporada.',
    categoria: 'topping',
  },
  {
    titulo: 'Ediciones limitadas',
    nota: 'Producción semanal reducida. Recomendamos reservar con 48 horas de anticipación.',
    categoria: 'edicion',
  },
];
---

<BaseLayout
  title="Catálogo — Manhattan & Ávila"
  description="Catálogo de New York Cheesecake artesanal en Caracas: formatos entero, medio y porción, toppings de parchita y frutos rojos, y ediciones limitadas. Precios en $ Ref."
>
  <section class="section intro">
    <div class="container">
      <span class="eyebrow">Catálogo</span>
      <h1>Todo lo que horneamos</h1>
      <p class="lead">
        Precios expresados en dólares de referencia ($ Ref). Pedidos con 24
        horas de anticipación; ediciones limitadas con 48. Entregas en toda
        el área metropolitana de Caracas.
      </p>
    </div>
  </section>

  {
    secciones.map((seccion, index) => (
      <section class:list={['section', { 'section--milk': index % 2 === 0 }]}>
        <div class="container">
          <h2>{seccion.titulo}</h2>
          <p class="seccion-nota">{seccion.nota}</p>
          <div class="grid">
            {productos
              .filter((p) => p.categoria === seccion.categoria)
              .map((producto) => (
                <ProductCard producto={producto} />
              ))}
          </div>
        </div>
      </section>
    ))
  }

  <section class="section">
    <div class="container pedido">
      <h2>¿Listo para ordenar?</h2>
      <p>
        Escríbenos por la página de contacto y confirma disponibilidad,
        toppings y horario de entrega.
      </p>
      <a href="/contacto/" class="btn btn--solid">Hacer un pedido</a>
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-bottom: var(--space-l);
  }

  .seccion-nota {
    margin-bottom: var(--space-m);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-m);
  }

  .pedido {
    text-align: center;
  }

  .pedido p {
    margin-inline: auto;
    margin-bottom: var(--space-m);
  }
</style>
