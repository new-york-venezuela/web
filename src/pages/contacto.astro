---
import BaseLayout from '../layouts/BaseLayout.astro';

// Datos de contacto parametrizables por variable de entorno,
// con valores de exhibición por defecto (nunca credenciales).
const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER as string | undefined;
const email =
  (import.meta.env.PUBLIC_CONTACT_EMAIL as string | undefined) ??
  'pedidos@alimentosnewyork.com';
---

<BaseLayout
  title="Contacto — New York Alimentos Premium"
  description="Contacta a New York Alimentos Premium en Caracas: dirección, horarios, teléfonos y canales de pedido para supermercados y servicio profesional."
>
  <section class="section">
    <div class="container">
      <span class="eyebrow">Contacto</span>
      <h1>¿Tienes preguntas o necesitas hacer un pedido?</h1>
      <p class="lead">
        Estamos disponibles para pedidos mayoristas, distribuidores y clientes directos.
        Ofrecemos soluciones personalizadas para supermercados, restaurantes y hoteles.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Tipos de Consultas que Atendemos</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <h3>Pedidos Mayoristas</h3>
          <p>
            ¿Eres distribuidor, supermercado o restaurante? Contáctanos para
            conocer nuestras opciones de volumen y precios especiales.
          </p>
        </div>
        <div class="faq-item">
          <h3>Información de Productos</h3>
          <p>
            Especificaciones técnicas, certificaciones, ingredientes y usos
            recomendados de nuestros productos.
          </p>
        </div>
        <div class="faq-item">
          <h3>Entregas y Logística</h3>
          <p>
            Consulta sobre entregas en Caracas, plazos de entrega, opciones de
            retiro y transporte de productos refrigerados.
          </p>
        </div>
        <div class="faq-item">
          <h3>Soluciones Personalizadas</h3>
          <p>
            ¿Necesitas un producto personalizado? Trabajamos con clientes para
            desarrollar soluciones adaptadas a tus necesidades.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Ubicación</h2>
      <p class="lead">
        Nos encuentras en la Zona Industrial de la Urbina, Caracas. Visitas y retiros
        se coordinan con cita previa.
      </p>
      <div class="map-container">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4317.725486513534!2d-66.80759997134044!3d10.490660421490189!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8c2a577fe1d1137b%3A0xe4bdd8df91120f4!2sNew%20York%20Chesse%20Cake!5e1!3m2!1sen!2sus!4v1784407301379!5m2!1sen!2sus"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <div class="location-details">
        <div class="detail-card">
          <h3>Dirección</h3>
          <p>
            Calle 10, Edificio JM<br />
            Zona Industrial de la Urbina<br />
            1070, Caracas, Miranda, Venezuela
          </p>
        </div>
        <div class="detail-card">
          <h3>Horarios</h3>
          <ul class="hours-list">
            <li><strong>Lunes a viernes:</strong> 8:00 a. m. — 5:00 p. m.</li>
            <li><strong>Sábados y domingos:</strong> Solo entregas programadas</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container cta-contact">
      <h2>¿Listo para hablar con nosotros?</h2>
      <p>
        Elige el canal más conveniente para comunicarte. Responderemos tu consulta
        dentro de las próximas 24 horas.
      </p>
      <div class="contact-actions">
        <a href={`tel:+584141552433`} class="btn btn--solid">Llamar Ahora</a>
        {
          whatsapp && (
            <a
              href={`https://wa.me/${whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--solid"
            >
              WhatsApp
            </a>
          )
        }
        <a href={`mailto:${email}`} class="btn btn--solid">Enviar Email</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .map-container {
    width: 100%;
    margin: 2rem 0;
    border-radius: 0.5rem;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .map-container iframe {
    display: block;
  }

  .location-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-m);
    margin-top: 2rem;
  }

  .detail-card {
    background-color: var(--color-cream);
    padding: var(--space-m);
    border-radius: 0.5rem;
  }

  .detail-card h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--color-charcoal);
  }

  .detail-card p {
    margin: 0;
    line-height: 1.7;
    color: var(--color-charcoal-soft);
  }

  .hours-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hours-list li {
    padding: 0.5rem 0;
    color: var(--color-charcoal-soft);
    line-height: 1.6;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-l);
    margin-top: 2rem;
  }

  .faq-item {
    background-color: var(--color-cream);
    padding: var(--space-m);
    border-radius: 0.5rem;
    border-left: 4px solid var(--color-accent);
  }

  .faq-item h3 {
    margin-top: 0;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    color: var(--color-charcoal);
  }

  .faq-item p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-charcoal-soft);
  }

  .cta-section {
    background-color: var(--color-cream);
  }

  .cta-contact {
    text-align: center;
  }

  .cta-contact h2 {
    margin-bottom: 1rem;
  }

  .cta-contact p {
    font-size: 1.125rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 40rem;
    margin-left: auto;
    margin-right: auto;
  }

  .contact-actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-m);
  }

  .contact-actions .btn {
    min-width: 12rem;
  }

  @media (max-width: 48rem) {
    .contact-actions {
      flex-direction: column;
    }

    .contact-actions .btn {
      width: 100%;
    }
  }
</style>
