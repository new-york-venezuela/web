---
import { formatPrecio, type Producto } from '../data/catalogo';

interface Props {
  producto: Producto;
}

const { producto } = Astro.props;

const etiquetas: Record<Producto['categoria'], string> = {
  clasico: 'Clásico',
  topping: 'Topping artesanal',
  edicion: 'Edición limitada',
};
---

<article class="card">
  <div class="card__media" aria-hidden="true">
    <span class="card__monogram">M&Á</span>
  </div>
  <div class="card__body">
    <span class="card__tag">{etiquetas[producto.categoria]}</span>
    <h3 class="card__title">{producto.nombre}</h3>
    <p class="card__description">{producto.descripcion}</p>
    <p class="card__detail">{producto.detalle}</p>
    <div class="card__footer">
      <span class="card__price">{formatPrecio(producto.precioRef)}</span>
      <span class="card__portions">{producto.porciones}</span>
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-cream);
    border: 1px solid var(--color-border);
    height: 100%;
  }

  .card__media {
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    background-color: var(--color-milk);
    border-bottom: 1px solid var(--color-border);
  }

  .card__monogram {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--color-border);
    letter-spacing: 0.05em;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-m);
  }

  .card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .card__title {
    font-size: 1.375rem;
    margin-bottom: var(--space-xs);
  }

  .card__description {
    font-size: 0.9375rem;
    margin-bottom: var(--space-s);
  }

  .card__detail {
    font-size: 0.8125rem;
    color: var(--color-charcoal-soft);
    margin-bottom: var(--space-m);
  }

  .card__footer {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    margin-top: auto;
    padding-top: var(--space-s);
    border-top: 1px solid var(--color-border);
  }

  .card__price {
    font-family: var(--font-display);
    font-size: 1.5rem;
  }

  .card__portions {
    font-size: 0.8125rem;
    color: var(--color-charcoal-soft);
  }
</style>
