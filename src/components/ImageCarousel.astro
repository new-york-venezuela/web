---
interface Props {
  imagenes: string[];
  alt: string;
  class?: string;
}

const { imagenes, alt, class: className } = Astro.props;

// Validate at least one image
if (!imagenes || imagenes.length === 0) {
  throw new Error('ImageCarousel requires at least one image');
}
---

<div class:list={['carousel', className]}>
  <div class="carousel__viewport">
    <img
      src={`/productos/${imagenes[0]}.png`}
      alt={alt}
      class="carousel__image"
      data-carousel-image
    />

    {imagenes.length > 1 && (
      <>
        <button
          class="carousel__button carousel__button--prev"
          aria-label="Previous image"
          data-action="prev"
        >
          ←
        </button>

        <button
          class="carousel__button carousel__button--next"
          aria-label="Next image"
          data-action="next"
        >
          →
        </button>

        <div class="carousel__counter" data-carousel-counter>
          1 / {imagenes.length}
        </div>
      </>
    )}
  </div>
</div>

<script define:vars={{ imagenes }}>
  (function initCarousel() {
    const carousel = document.currentScript.closest('.carousel');
    if (!carousel) return;

    let currentIndex = 0;

    const image = carousel.querySelector('[data-carousel-image]');
    const counter = carousel.querySelector('[data-carousel-counter]');

    function updateImage() {
      const slug = imagenes[currentIndex];
      image.src = `/productos/${slug}.png`;
      if (counter) {
        counter.textContent = `${currentIndex + 1} / ${imagenes.length}`;
      }
    }

    function handleButtonClick(e) {
      e.preventDefault();
      const action = this.getAttribute('data-action');
      if (action === 'prev') {
        currentIndex = (currentIndex - 1 + imagenes.length) % imagenes.length;
      } else if (action === 'next') {
        currentIndex = (currentIndex + 1) % imagenes.length;
      }
      updateImage();
    }

    function handleKeydown(e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        currentIndex = (currentIndex - 1 + imagenes.length) % imagenes.length;
        updateImage();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        currentIndex = (currentIndex + 1) % imagenes.length;
        updateImage();
      }
    }

    // Attach click handlers to buttons
    const buttons = carousel.querySelectorAll('[data-action]');
    buttons.forEach(btn => {
      btn.addEventListener('click', handleButtonClick);
    });

    carousel.addEventListener('keydown', handleKeydown);
  })();
</script>

<style>
  .carousel {
    width: 100%;
  }

  .carousel__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--color-milk);
    border-radius: 0.5rem;
  }

  .carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__image {
      transition: none;
    }
  }

  .carousel__button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: white;
    font-size: 1.75rem;
    cursor: pointer;
    padding: 0.5rem 0.75rem;
    line-height: 1;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease, transform 0.2s ease;
    z-index: 10;
    pointer-events: auto;
  }

  .carousel__button:hover {
    background-color: rgba(0, 0, 0, 0.85);
    transform: translateY(-50%) scale(1.1);
  }

  .carousel__button:active {
    transform: translateY(-50%) scale(0.95);
  }

  .carousel__button:focus {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .carousel__button--prev {
    left: 0.5rem;
  }

  .carousel__button--next {
    right: 0.5rem;
  }

  .carousel__counter {
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.875rem;
    color: white;
    background: rgba(0, 0, 0, 0.5);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    z-index: 10;
  }

</style>
