---
import { Image } from 'astro:assets';
import { getProductImage } from '../utils/getProductImage';

interface Props {
  imagenes: string[];
  alt: string;
  class?: string;
}

const { imagenes, alt, class: className } = Astro.props;

if (!imagenes || imagenes.length === 0) {
  throw new Error('ImageCarousel requires at least one image');
}

// Pre-load all carousel images for switching
const imagenesData = imagenes.map(slug => ({
  slug,
  data: getProductImage(slug),
}));

const primeraImagenData = imagenesData[0].data;
---

<div class:list={['carousel', className]}>
  <div class="carousel__viewport">
    {primeraImagenData ? (
      <Image
        src={primeraImagenData}
        alt={alt}
        width={700}
        height={560}
        sizes="(max-width: 640px) 350px, (max-width: 1024px) 500px, 700px"
        class="carousel__image"
        data-carousel-image
        data-index="0"
      />
    ) : (
      <img
        src={`/productos/${imagenes[0]}.png`}
        alt={alt}
        class="carousel__image"
        data-carousel-image
        data-index="0"
      />
    )}

    {/* Pre-render all carousel images (hidden) to preload srcset */}
    {imagenesData.slice(1).map((item, idx) => (
      item.data && (
        <Image
          src={item.data}
          alt={alt}
          width={350}
          height={280}
          sizes="(max-width: 640px) 350px, (max-width: 1024px) 500px, 700px"
          class="carousel__preload"
          data-carousel-preload
          data-index={idx + 1}
          loading="lazy"
          style="display:none"
        />
      )
    ))}

    {imagenes.length > 1 && (
      <>
        <button
          class="carousel__button carousel__button--prev"
          aria-label="Previous image"
          data-action="prev"
        >
          ←
        </button>

        <button
          class="carousel__button carousel__button--next"
          aria-label="Next image"
          data-action="next"
        >
          →
        </button>

        <div class="carousel__counter" data-carousel-counter>
          1 / {imagenes.length}
        </div>
      </>
    )}
  </div>
</div>

<script define:vars={{ imagenes }}>
  (function initCarousel() {
    const carousel = document.currentScript.previousElementSibling;
    if (!carousel || !carousel.classList.contains('carousel')) return;

    let currentIndex = 0;

    const activeImage = carousel.querySelector('[data-carousel-image]');
    const viewport = carousel.querySelector('.carousel__viewport');
    const counter = carousel.querySelector('[data-carousel-counter]');
    const prevBtn = carousel.querySelector('[data-action="prev"]');
    const nextBtn = carousel.querySelector('[data-action="next"]');

    // Build map of index -> source, including the original (index 0) image.
    // We snapshot index 0's src/srcset up front because activeImage is the
    // same DOM node we mutate on every swap - once we overwrite it there is
    // no other element left holding the original picture to go back to.
    const sourcesMap = {
      0: { src: activeImage.src, srcset: activeImage.srcset },
    };
    viewport.querySelectorAll('[data-carousel-preload]').forEach(img => {
      const idx = img.getAttribute('data-index');
      sourcesMap[idx] = { src: img.src, srcset: img.srcset };
    });

    function updateImage() {
      const source = sourcesMap[currentIndex];
      if (source) {
        activeImage.src = source.src;
        // Always assign srcset (even if empty) - otherwise a previous
        // swap's srcset lingers on the element and browsers prefer it
        // over the new src when it still matches the current viewport.
        activeImage.srcset = source.srcset || '';
        activeImage.style.opacity = '1';
      }

      if (counter) {
        counter.textContent = `${currentIndex + 1} / ${imagenes.length}`;
      }
    }

    function goToPrev() {
      currentIndex = (currentIndex - 1 + imagenes.length) % imagenes.length;
      updateImage();
    }

    function goToNext() {
      currentIndex = (currentIndex + 1) % imagenes.length;
      updateImage();
    }

    function handleKeydown(e) {
      if (e.key === 'ArrowLeft') {
        e.preventDefault();
        goToPrev();
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        goToNext();
      }
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        goToPrev();
        this.blur();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        goToNext();
        this.blur();
      });
    }

    carousel.addEventListener('keydown', handleKeydown);
  })();
</script>

<style>
  .carousel {
    width: 100%;
  }

  .carousel__viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 4;
    overflow: hidden;
    background-color: var(--color-milk);
    border-radius: 0.5rem;
  }

  .carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__image {
      transition: none;
    }
  }

  .carousel__button {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.5);
    border: none;
    color: white;
    font-size: 1.75rem;
    cursor: pointer;
    padding: 0.5rem 0.75rem;
    line-height: 1;
    border-radius: 0.25rem;
    transition: background-color 0.2s ease, transform 0.2s ease;
    z-index: 1;
    pointer-events: auto;
  }

  @media (hover: hover) and (pointer: fine) {
    .carousel__button:hover {
      background-color: rgba(0, 0, 0, 0.85);
      transform: translateY(-50%) scale(1.1);
    }
  }

  .carousel__button:active {
    transform: translateY(-50%) scale(0.95);
  }

  @media (pointer: coarse) {
    .carousel__button:active {
      transform: translateY(-50%) scale(0.95);
    }

    .carousel__button:not(:focus-visible) {
      background-color: rgba(0, 0, 0, 0.5);
      transform: translateY(-50%);
    }
  }

  .carousel__button:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .carousel__button--prev {
    left: 0.5rem;
  }

  .carousel__button--next {
    right: 0.5rem;
  }

  .carousel__counter {
    position: absolute;
    bottom: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.875rem;
    color: white;
    background: rgba(0, 0, 0, 0.5);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    z-index: 1;
  }

</style>
