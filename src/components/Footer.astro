---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__brand">Manhattan &amp; Ávila</p>
      <p class="site-footer__tagline">
        New York Cheesecake artesanal, horneado en Caracas.
      </p>
    </div>
    <ul class="site-footer__links">
      <li><a href="/catalogo/">Catálogo</a></li>
      <li><a href="/sobre-nosotros/">Nosotros</a></li>
      <li><a href="/contacto/">Contacto</a></li>
    </ul>
  </div>
  <div class="container site-footer__legal">
    <p>© {year} Manhattan &amp; Ávila, C.A. — Caracas, Venezuela. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-milk);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-l) var(--space-m);
    margin-top: auto;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-m);
    padding-bottom: var(--space-m);
  }

  .site-footer__brand {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-xs);
  }

  .site-footer__tagline {
    font-size: 0.9375rem;
    margin: 0;
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-m);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Área táctil cómoda sin alterar el ritmo visual. */
  .site-footer__links a {
    display: inline-block;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-block: 0.625rem;
  }

  .site-footer__legal {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-m);
  }

  .site-footer__legal p {
    font-size: 0.8125rem;
    margin: 0;
  }
</style>
