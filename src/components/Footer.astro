---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div>
      <p class="site-footer__brand">New York</p>
      <p class="site-footer__tagline">
        Alimentos Premium
      </p>
      <div class="site-footer__contact">
        <p><strong>Dirección:</strong> Calle 10, Edificio JM, Zona Industrial de la Urbina, 1070, Caracas, Miranda</p>
        <p><strong>Ventas:</strong> <a href="tel:+584141552433">+58 414 155 2433</a> · <a href="https://wa.me/584141552433" class="whatsapp-link" target="_blank" rel="noopener noreferrer">💬 WhatsApp</a></p>
        <p><strong>Oficina:</strong> <a href="tel:+582122418035">+58 212 241 8035</a> / <a href="tel:+582122419059">9059</a></p>
      </div>
    </div>
    <div class="site-footer__column-right">
        <ul class="site-footer__links">
          <li><a href="/catalogo/">Catálogo</a></li>
          <li><a href="/sobre-nosotros/">Nosotros</a></li>
          <li><a href="/contacto/">Contacto</a></li>
        </ul>
        <img
          src="/logos/classic.png"
          alt="New York Alimentos Premium"
          class="site-footer__logo"
        />
    </div>
  </div>
  <div class="container site-footer__legal">
    <p>© {year} New York Cheese Cake C.A. — Caracas, Venezuela. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-milk);
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-l) var(--space-m);
    margin-top: auto;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-m);
    padding-bottom: var(--space-m);
  }

  .site-footer__brand {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--color-charcoal);
    margin-bottom: var(--space-xs);
  }

  .site-footer__tagline {
    font-size: 0.9375rem;
    margin: 0;
  }

  .site-footer__contact {
    font-size: 0.8125rem;
    margin-top: var(--space-s);
    line-height: 1.6;
  }

  .site-footer__contact p {
    margin: 0.25rem 0;
  }

  .site-footer__contact a {
    color: inherit;
    text-decoration: none;
  }

  .site-footer__contact a:hover {
    text-decoration: underline;
  }

  .whatsapp-link {
    color: #25d366;
    font-weight: 500;
  }

  .whatsapp-link:hover {
    opacity: 0.8;
  }

  .site-footer__links {
    display: flex;
    gap: var(--space-m);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Área táctil cómoda sin alterar el ritmo visual. */
  .site-footer__links a {
    display: inline-block;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-block: 0.625rem;
  }

  .site-footer__column-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-m);
  }

  .site-footer__logo {
    width: 140px;
    height: auto;
    display: block;
  }

  .site-footer__legal {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-m);
  }

  .site-footer__legal p {
    font-size: 0.8125rem;
    margin: 0;
  }
</style>
