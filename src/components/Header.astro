---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo/', label: 'Catálogo' },
  { href: '/sobre-nosotros/', label: 'Nosotros' },
  { href: '/contacto/', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label="Manhattan & Ávila — Inicio">
      Manhattan <span aria-hidden="true">&</span> Ávila
    </a>
    <nav aria-label="Navegación principal">
      <ul class="site-header__nav">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background-color: var(--color-cream);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  /* Mobile-first: marca y navegación apiladas y centradas; sin JS. */
  .site-header__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding-block: 0.875rem;
    text-align: center;
  }

  .site-header__brand {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 1.5rem);
    letter-spacing: 0.02em;
    padding-block: 0.25rem;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.75rem, 3vw, 2.5rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Área táctil ≥44px: el padding vertical suma a la altura de línea. */
  .site-header__nav a {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding-block: 0.75rem;
    border-bottom: 1px solid transparent;
  }

  @media (min-width: 40rem) {
    .site-header__inner {
      flex-direction: row;
      justify-content: space-between;
      gap: var(--space-s);
      padding-block: 0.75rem;
      text-align: left;
    }

    .site-header__nav a {
      font-size: 0.8125rem;
      letter-spacing: 0.14em;
    }
  }

  .site-header__nav a[aria-current='page'] {
    border-bottom-color: var(--color-charcoal);
  }
</style>
