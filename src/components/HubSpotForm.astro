---
const portalId = import.meta.env.PUBLIC_HUBSPOT_PORTAL_ID as string;
const formId = import.meta.env.PUBLIC_HUBSPOT_FORM_ID as string;

if (!portalId || !formId) {
  throw new Error('HubSpot Portal ID and Form ID are required. Check PUBLIC_HUBSPOT_PORTAL_ID and PUBLIC_HUBSPOT_FORM_ID in .env');
}
---

<div class="hubspot-form-wrapper">
  <div id="hubspot-loader" class="loader">
    <div class="spinner"></div>
    <p>Cargando formulario...</p>
  </div>
  <div id="hubspot-error" class="error-message" style="display: none;">
    <p>No pudimos cargar el formulario. Por favor, intenta recargar la página.</p>
  </div>
  <div id="hubspot-form-container"></div>
</div>

<script define:vars={{ portalId, formId }}>
  const hideLoader = (isError = false) => {
    const loader = document.getElementById('hubspot-loader');
    const error = document.getElementById('hubspot-error');
    if (loader) {
      loader.style.display = 'none';
    }
    if (isError && error) {
      error.style.display = 'block';
    }
  };

  let loaderHidden = false;
  const ensureLoaderHidden = (isError = false) => {
    if (!loaderHidden) {
      hideLoader(isError);
      loaderHidden = true;
    }
  };

  let observer;
  const setupFormObserver = () => {
    const formContainer = document.getElementById('hubspot-form-container');
    if (!formContainer) return;

    observer = new MutationObserver(() => {
      const iframe = formContainer.querySelector('iframe');
      // Wait for iframe to have height (indicates it's rendered and interactive)
      if (iframe && iframe.offsetHeight > 0) {
        clearFallback();
        ensureLoaderHidden();
        observer.disconnect();
      }
    });

    observer.observe(formContainer, {
      childList: true,
      subtree: true,
      attributes: true
    });
  };

  // Fallback: hide loader after timeout (guards against script/network/config failures)
  const fallbackTimeout = setTimeout(() => {
    console.warn('HubSpot form did not load within 10s, hiding loader');
    if (observer) observer.disconnect();
    ensureLoaderHidden();
  }, 10000);

  const clearFallback = () => {
    clearTimeout(fallbackTimeout);
    if (observer) observer.disconnect();
  };

  const createForm = () => {
    if (window.hbspt) {
      setupFormObserver();
      window.hbspt.forms.create({
        region: 'na1',
        portalId: portalId,
        formId: formId,
        target: '#hubspot-form-container',
        onFormReady: () => {
          clearFallback();
          ensureLoaderHidden(false);
        }
      });
    }
  };

  // Load HubSpot embed script if not already loaded
  if (!window.hbspt) {
    const script = document.createElement('script');
    script.src = 'https://js.hsforms.net/forms/embed/v2.js';
    script.async = true;
    script.onload = createForm;
    script.onerror = () => {
      console.error('Failed to load HubSpot embed script');
      clearFallback();
      ensureLoaderHidden(true);
    };
    document.body.appendChild(script);
  } else {
    // Script already loaded, create form immediately
    createForm();
  }
</script>

<style>
  .hubspot-form-wrapper {
    width: 100%;
  }

  .loader {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    gap: 1rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid #f3f3f3;
    border-top: 4px solid #3498db;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  .loader p {
    color: #666;
    font-size: 0.95rem;
    margin: 0;
  }

  .error-message {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background-color: #fee;
    border-left: 4px solid #d32f2f;
    border-radius: 4px;
  }

  .error-message p {
    color: #d32f2f;
    font-size: 0.95rem;
    margin: 0;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>
