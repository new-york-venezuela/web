# ============================================================
# Variables de entorno — plantilla
# Copiar a `.env` y completar. `.env` está ignorado por git.
# El prefijo PUBLIC_ expone la variable al cliente (Astro).
# No colocar aquí valores reales: este archivo SÍ se versiona.
# ============================================================

# --- PostHog Analytics (opcional: si falta la clave, no se inicializa) ---
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_API_HOST=https://us.i.posthog.com
PUBLIC_POSTHOG_UI_HOST=

# --- Google Forms (landing oculta /landing/promocion) ---
# ID público del formulario: docs.google.com/forms/d/e/<ID>/formResponse
# Las respuestas se vuelcan automáticamente a la Google Sheet vinculada,
# sin exponer credenciales de la API de Sheets.
PUBLIC_GOOGLE_FORM_ID=
# IDs de campo del formulario (inspeccionar la vista previa: entry.XXXXXXXX)
PUBLIC_GFORM_ENTRY_NOMBRE=
PUBLIC_GFORM_ENTRY_TELEFONO=
PUBLIC_GFORM_ENTRY_PRODUCTO=
PUBLIC_GFORM_ENTRY_MENSAJE=

# --- HubSpot Forms ---
PUBLIC_HUBSPOT_PORTAL_ID=
PUBLIC_HUBSPOT_FORM_ID=

# --- Datos de contacto parametrizables ---
PUBLIC_WHATSAPP_NUMBER=
PUBLIC_CONTACT_EMAIL=

# --- Automated Blog Generator ---
# GitHub API token (required for issue queries)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM Provider Configuration
# Choose one provider and set the corresponding variables below

# OpenAI (default)
AI_MODEL=gpt-4
AI_PROVIDER_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude (Anthropic)
# AI_MODEL=claude-3-5-sonnet-20241022
# AI_PROVIDER_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.anthropic.com/v1

# Local/Custom (e.g., Ollama, vLLM)
# AI_MODEL=mistral
# AI_BASE_URL=http://localhost:8000/v1
# AI_PROVIDER_API_KEY=not-used

# Repository and output paths
GITHUB_REPO=eugenio/new-york-venezuela-web
BLOG_OUTPUT_DIR=src/content/blog

# Blog generation settings
ISSUE_LABEL=blog-post-idea
DEBUG=false
