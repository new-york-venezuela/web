# ============================================================
# Variables de entorno — plantilla
# Copiar a `.env` y completar. `.env` está ignorado por git.
# El prefijo PUBLIC_ expone la variable al cliente (Astro).
# No colocar aquí valores reales: este archivo SÍ se versiona.
# ============================================================

# --- PostHog Analytics (opcional: si falta la clave, no se inicializa) ---
PUBLIC_POSTHOG_KEY=
# Reverse proxy domain (ej: https://ua.alimentosnewyork.com)
PUBLIC_POSTHOG_API_HOST=https://us.i.posthog.com
# PostHog UI host (obligatorio con reverse proxy)
PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# --- Formulario de contacto: elegir HUBSPOT o GOOGLE_SHEETS ---

# HubSpot (recomendado para nuevo setup — ver docs/HUBSPOT_SETUP_2026.md)
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_ID=
# Opcional: mapeo personalizado de campos (JSON). Por defecto:
# { "fullName": "firstname", "phone": "phone", "email": "email",
#   "businessType": "businesstype", "companyName": "company", "message": "message" }
HUBSPOT_FIELD_MAPPING=

# Google Sheets (legacy — fallback si HubSpot no está configurado)
GOOGLE_SHEET_ID=
GOOGLE_PROJECT_ID=
GOOGLE_PRIVATE_KEY_ID=
GOOGLE_PRIVATE_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_CLIENT_ID=

# --- Google Forms (landing oculta /landing/promocion) ---
# ID público del formulario: docs.google.com/forms/d/e/<ID>/formResponse
# Las respuestas se vuelcan automáticamente a la Google Sheet vinculada,
# sin exponer credenciales de la API de Sheets.
PUBLIC_GOOGLE_FORM_ID=
# IDs de campo del formulario (inspeccionar la vista previa: entry.XXXXXXXX)
PUBLIC_GFORM_ENTRY_NOMBRE=
PUBLIC_GFORM_ENTRY_TELEFONO=
PUBLIC_GFORM_ENTRY_PRODUCTO=
PUBLIC_GFORM_ENTRY_MENSAJE=

# --- Datos de contacto parametrizables ---
PUBLIC_WHATSAPP_NUMBER=
PUBLIC_CONTACT_EMAIL=
